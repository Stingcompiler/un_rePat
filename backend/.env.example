# ── Copy this file to .env and fill in real values ──────────────────────────
# cp .env.example .env

# Django Core
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=musabstingdev.pythonanywhere.com,www.musabstingdev.pythonanywhere.com

# Database (SQLite is the default — remove DB_* lines to keep using it)
# For MySQL on PythonAnywhere (Databases tab):
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=musabstingdev$university_db
# DB_USER=musabstingdev
# DB_PASSWORD=your-mysql-password
# DB_HOST=musabstingdev.mysql.pythonanywhere-services.com
# DB_PORT=3306

# CORS & CSRF — must match your actual domain
CORS_ALLOWED_ORIGINS=https://musabstingdev.pythonanywhere.com,https://www.musabstingdev.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://musabstingdev.pythonanywhere.com,https://www.musabstingdev.pythonanywhere.com
